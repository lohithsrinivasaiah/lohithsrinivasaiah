# Groq API key for the chat feature (get free key from console.groq.com)
VITE_GROQ_API_KEY=your_key_here

# Optional GitHub Personal Access Token for higher rate limits (5k req/hr vs 60/hr without)
# Create at https://github.com/settings/tokens (scopes: public_repo, read:user)
VITE_GITHUB_TOKEN=your_github_pat_here
